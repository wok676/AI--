# ---- Secrets (零硬编码密钥铁律) ----
.env
.env.*
!.env.example
# 例外:所有 *.example 样板(占位无真值)必须入库,如 .env.production.example
!*.env.example
!.env*.example
*.key
*.pem
*.p8
*.p12
*.keystore
*.jks
google-services.json
GoogleService-Info.plist

# ---- Node ----
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-error.log*
.pnpm-store/

# ---- Build / dist ----
dist/
build/
*.tsbuildinfo

# ---- 构建出的移动安装包(不提交二进制) ----
*.apk
*.aab
*.ipa

# ---- Flutter 原生工程:保留配置,仅忽略机器相关/构建产物 ----
# 注:app/android、app/ios 的源码配置必须入库(Flutter 不像 Expo 靠 prebuild 重生成)
**/android/local.properties
**/android/.gradle/
**/android/.kotlin/
**/android/captures/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/ephemeral/
**/ios/Pods/
**/ios/.symlinks/
**/ios/**/xcuserdata/

# ---- Docker / runtime ----
*.local
pgdata/

# ---- 生产 TLS 证书与加密备份(绝不入库,部署机本地就位)----
deploy/nginx/certs/
deploy/nginx/acme-challenge/
deploy/backups/

# ---- SQLite 本地库 ----
*.db
*.db-journal
*.sqlite

# ---- Prisma 生成产物 ----
generated/

# ---- Git worktree 并行隔离目录(见 docs/WORKFLOW.md) ----
.worktrees/

# ---- UI 走查截图(本机工作产物,勿入库) ----
.ui-review/

# ---- Claude 本机设置 ----
.claude/settings.local.json

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# ---- Logs ----
logs/
*.log
