# ============================================================
# TestAI 生产起栈环境变量样板(占位无真值)· 上位法 CLAUDE.md §1.4 / §6
# 复制为 deploy/.env.production 并填真值;.env.production 已被 .gitignore 忽略,严禁提交。
#
# 「本地 -> 生产」只改本文件里的地址/域名/密钥三类变量,代码一行不动。
# ============================================================

# ---- 公网域名(切生产必改:nginx server_name 与对外访问地址)----
# 同步把 deploy/nginx/prod.conf 里的 __DOMAIN__ 替换成此域名(或用 envsubst)。
DOMAIN=__REPLACE_WITH_YOUR_DOMAIN__            # 例:api.testai.example.com

# ---- PostgreSQL(生产用强随机口令)----
POSTGRES_USER=testai
POSTGRES_PASSWORD=__REPLACE_WITH_STRONG_DB_PASSWORD__
POSTGRES_DB=testai
# server 容器内连库地址由上面三项拼成 db:5432;此处仅供宿主侧工具参考。
DATABASE_URL=postgresql://testai:__REPLACE_WITH_STRONG_DB_PASSWORD__@db:5432/testai?schema=public

# ---- JWT(生产必须全新强随机,勿复用 dev)----
JWT_ACCESS_SECRET=__REPLACE_WITH_STRONG_RANDOM_SECRET__   # openssl rand -base64 48
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- CORS(生产必须收紧到真实前端/后台来源,逗号分隔;禁止留空=放行所有)----
CORS_ORIGINS=https://__REPLACE_WITH_ADMIN_OR_WEB_ORIGIN__

# ---- 限流 ----
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# ---- i18n ----
DEFAULT_LOCALE=en

# ---- Sign in with Apple ----
APPLE_AUDIENCE=com.testai.app
APPLE_ISSUER=https://appleid.apple.com

# ---- 识别限流 / 原图大小上限 ----
RECOGNITION_DAILY_LIMIT=30
RECOGNITION_MAX_IMAGE_BYTES=8388608

# ---- Claude 视觉/文本识别(后端代理,密钥绝不下发客户端 §6)----
ANTHROPIC_API_KEY=__REPLACE_WITH_REAL_KEY__
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TIMEOUT_MS=20000

# ---- 每日加密备份(backup profile 用;对称加密口令,绝不入库)----
BACKUP_GPG_PASSPHRASE=__REPLACE_WITH_STRONG_BACKUP_PASSPHRASE__
