# ============================================================
# TestAI 本地 dev 起栈环境变量样板(占位无真值)
# 复制为 deploy/.env 并填入真实值;deploy/.env 已被 .gitignore 忽略,严禁提交。
# 零硬编码密钥铁律 CLAUDE.md §1.4 / §6。
# ============================================================

# ---- PostgreSQL(db 服务)----
# 本地 dev 可用简单值;这三项同时决定 server 的 DATABASE_URL(compose 内部拼接)
POSTGRES_USER=testai
POSTGRES_PASSWORD=__REPLACE_WITH_LOCAL_DB_PASSWORD__
POSTGRES_DB=testai

# ---- DATABASE_URL ----
# 说明:容器内 server 连库地址由 compose 用上面三项拼成 postgresql://USER:PASS@db:5432/DB
# 此处单列仅作宿主机侧工具(如本机 psql / prisma studio)连库参考;改了上面三项请同步这里。
DATABASE_URL=postgresql://testai:__REPLACE_WITH_LOCAL_DB_PASSWORD__@localhost:5432/testai?schema=public

# ---- JWT(access token,无状态)----
# 强随机值,例:openssl rand -base64 48
JWT_ACCESS_SECRET=__REPLACE_WITH_STRONG_RANDOM_SECRET__
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- CORS(留空 = 本地放行所有 origin,便于联调)----
CORS_ORIGINS=

# ---- 限流 ----
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# ---- i18n ----
DEFAULT_LOCALE=en

# ---- Sign in with Apple ----
APPLE_AUDIENCE=com.testai.app
APPLE_ISSUER=https://appleid.apple.com

# ---- 识别限流 / 原图大小上限 ----
RECOGNITION_DAILY_LIMIT=30
RECOGNITION_MAX_IMAGE_BYTES=8388608

# ---- Claude 视觉/文本识别(后端代理,密钥绝不下发客户端 §6)----
# 缺它则仅 /recognition 识别相关端点不可用,注册/登录/记餐/汇总等其余功能照常。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TIMEOUT_MS=20000
