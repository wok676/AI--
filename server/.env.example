# ============================================================
# TestAI backend env sample — 占位无真值(零硬编码密钥铁律 §1.4 / §6)
# 复制为 .env 并填入真实值;.env 已被 .gitignore 忽略,严禁提交。
# ============================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000
# /api/v1 前缀由代码固定;此处仅为对外可声明的基址(部署用)
API_BASE_URL=http://localhost:3000

# ---- Database ----
# 本地开发可用 SQLite:file:./dev.db
# 生产切 PostgreSQL:postgresql://user:password@host:5432/testai?schema=public
DATABASE_URL=file:./dev.db

# ---- JWT(access token,15min,无状态)----
# 用强随机值(如 openssl rand -base64 48);绝不提交真实值
JWT_ACCESS_SECRET=__REPLACE_WITH_STRONG_RANDOM_SECRET__
JWT_ACCESS_TTL=15m
# refreshToken 为不透明随机串,服务端只存 sha256;此为额外的哈希盐(可选)
REFRESH_TOKEN_TTL_DAYS=30

# ---- CORS 白名单(逗号分隔;留空=开发放行 localhost)----
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ---- 限流(全局)----
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# ---- i18n ----
DEFAULT_LOCALE=en

# ---- Sign in with Apple(校验 identityToken)----
# 服务端 services id / bundle id 作为 aud 校验
APPLE_AUDIENCE=com.testai.app
APPLE_ISSUER=https://appleid.apple.com

# ---- 识别每日上限(F10 / DB §8)----
RECOGNITION_DAILY_LIMIT=30
# 原图大小上限(字节,API.md §4.10 默认 8MB);超限拒绝,原图不落库
RECOGNITION_MAX_IMAGE_BYTES=8388608

# ---- Claude 视觉/文本识别(后端代理,密钥绝不下发客户端 §6)----
# 强随机密钥走 .env,严禁提交真实值
ANTHROPIC_API_KEY=
# 默认最新 Claude 模型;可覆盖
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TIMEOUT_MS=20000
