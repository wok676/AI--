// ============================================================
// TestAI · Prisma schema (AI 饮食热量记录 v1)
// 严格对齐 docs/DB-Schema.md(FROZEN）。字段名/类型逐字段对齐。
// 上位法 CLAUDE.md §6(横向归属 ownerId + 纵向 RBAC + 零明文密码 + 注销彻底销毁)。
//
// 数据库:PostgreSQL(部署)。本地开发若无 Postgres,可改 provider="sqlite"
// 并把 enum 降级为 String(SQLite 不支持原生 enum)。本轮以 Postgres 为基准跑 migration。
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- 枚举(DB-Schema §1)----------------

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
}

enum AuthProvider {
  EMAIL // 邮箱密码
  APPLE // Sign in with Apple
  GOOGLE // 预留,v1 不启用
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum Sex {
  MALE
  FEMALE
  UNSPECIFIED
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum GoalType {
  LOSE
  MAINTAIN
  GAIN
}

enum AccountStatus {
  ACTIVE
  BANNED
  // 注:注销不是状态,而是物理删除整行;不保留软删墓碑(PRD §4.2 不可逆)
}

enum RecognitionSource {
  PHOTO
  GALLERY
  TEXT
}

// ---------------- User(账号 · 鉴权主体,DB-Schema §2)----------------

model User {
  id                String        @id @default(cuid())
  email             String?       @unique // 可空(纯 Apple 私密中继可能无邮箱);小写归一化存储
  emailVerified     Boolean       @default(false)
  passwordHash      String? // argon2id 哈希,绝不明文;第三方登录无密码
  username          String
  role              Role          @default(USER)
  plan              Plan          @default(FREE)
  status            AccountStatus @default(ACTIVE)
  avatarUrl         String?
  locale            String        @default("en")
  unitEnergy        String        @default("kcal") // kcal / kj
  unitMass          String        @default("g") // g / oz
  notifyEnabled     Boolean       @default(false)
  consentAcceptedAt DateTime? // 知情同意时间戳(§4.1 合规证据)
  consentVersion    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  authIdentities    AuthIdentity[]
  profile           Profile?
  dailyGoals        DailyGoal[]
  mealEntries       MealEntry[]
  refreshTokens     RefreshToken[]
  recognitionUsages RecognitionUsage[]
  recognitionAudits RecognitionAudit[] // onDelete: SetNull(注销去标识)

  @@index([status])
}

// ---------------- AuthIdentity(多渠道登录身份,DB-Schema §3)----------------

model AuthIdentity {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String // Apple/Google sub;EMAIL 渠道存 email
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

// ---------------- RefreshToken(刷新令牌 · 可吊销,DB-Schema §4)----------------

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // refreshToken 的 sha256 哈希,不存原文
  expiresAt DateTime
  revokedAt DateTime? // 登出/注销主动吊销
  createdAt DateTime  @default(now())
  userAgent String? // 设备指纹(脱敏)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------- Profile(个人资料 1:1,DB-Schema §5)----------------

model Profile {
  id            String         @id @default(cuid())
  userId        String         @unique
  sex           Sex            @default(UNSPECIFIED)
  birthYear     Int? // 仅存年份,降低敏感度
  heightCm      Float?
  weightKg      Float?
  activityLevel ActivityLevel?
  goalType      GoalType?
  updatedAt     DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------- MealEntry + FoodItem(核心业务,DB-Schema §6)----------------

model MealEntry {
  id            String            @id @default(cuid())
  ownerId       String // 横向归属字段(§6)
  mealType      MealType
  consumedAt    DateTime
  localDate     String // 用户本地日期 YYYY-MM-DD,每日汇总聚合键
  source        RecognitionSource
  note          String?
  totalKcal     Float             @default(0) // 冗余合计(写时计算)
  totalProteinG Float             @default(0)
  totalCarbsG   Float             @default(0)
  totalFatG     Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  owner User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items FoodItem[]

  @@index([ownerId, localDate])
  @@index([ownerId, consumedAt])
}

model FoodItem {
  id          String   @id @default(cuid())
  mealEntryId String
  ownerId     String // 冗余横向归属(直接查/改单项免 join)
  name        String
  quantity    Float    @default(1)
  unit        String   @default("serving")
  kcal        Float    @default(0)
  proteinG    Float    @default(0)
  carbsG      Float    @default(0)
  fatG        Float    @default(0)
  confidence  Float? // 0..1,AI 置信度
  isManual    Boolean  @default(false)
  createdAt   DateTime @default(now())

  mealEntry MealEntry @relation(fields: [mealEntryId], references: [id], onDelete: Cascade)

  @@index([mealEntryId])
  @@index([ownerId])
}

// ---------------- DailyGoal(每日目标,DB-Schema §7)----------------

model DailyGoal {
  id            String   @id @default(cuid())
  ownerId       String // 横向归属
  targetKcal    Int
  effectiveFrom String // 生效起始本地日期 YYYY-MM-DD
  source        String   @default("manual") // manual / estimated
  createdAt     DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, effectiveFrom])
  @@index([ownerId])
}

// ---------------- RecognitionUsage(每日识别限流,DB-Schema §8)----------------

model RecognitionUsage {
  id        String   @id @default(cuid())
  ownerId   String
  localDate String // 计数自然日 YYYY-MM-DD
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, localDate])
  @@index([ownerId, localDate])
}

// ---------------- RecognitionAudit(AI 调用审计 · 脱敏聚合,DB-Schema §9)----------------
// 注销策略例外:onDelete: SetNull —— 注销后行仍在但 ownerId=NULL,不可逆去标识化,
// 仅作聚合统计(DAU/调用量/失败率),不含任何可还原个人的字段。全表唯一不物理删除的例外。

model RecognitionAudit {
  id        String            @id @default(cuid())
  ownerId   String? // 注销时置 NULL
  source    RecognitionSource
  success   Boolean
  latencyMs Int?
  model     String?
  errorCode String? // 非 PII
  createdAt DateTime          @default(now())

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([success])
}
