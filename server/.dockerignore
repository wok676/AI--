# 构建上下文裁剪:避免把本地产物/密钥/SQLite 资产带进镜像
node_modules
dist
coverage
*.log
*.tsbuildinfo

# 本地 SQLite 开发资产(镜像跑 PostgreSQL,绝不带入)
prisma/dev.db
prisma/dev.db-journal
prisma/prisma
prisma/schema.sqlite.prisma
prisma/migrations
**/*.db
**/*.db-journal

# 环境与密钥(零硬编码密钥铁律 §1.4 / §6)
.env
.env.*
!.env.example

# 杂项
.git
.gitignore
Dockerfile
.dockerignore
