# 环境变量样板（仅占位，无真实值）。复制为 .env 后填入真实值，.env 绝不入库。
# 对应 CLAUDE.md §6 安全：所有密钥走环境变量，密码哈希存储。

# ---- 通用 ----
NODE_ENV=development
APP_NAME=TestAI

# ---- 后端 ----
PORT=3000
# 数据库（本地可 SQLite，部署切 PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/testai?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=testai

# ---- 鉴权（JWT）----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_too
JWT_REFRESH_EXPIRES_IN=7d

# ---- i18n ----
DEFAULT_LOCALE=zh
FALLBACK_LOCALE=en

# ---- 前端（Expo，公开变量需 EXPO_PUBLIC_ 前缀）----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ---- 第三方 SDK（按需，沙箱）----
# PAYMENT_API_KEY=
# PUSH_SERVICE_KEY=
